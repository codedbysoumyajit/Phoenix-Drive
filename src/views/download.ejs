<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Phoenix-XShare file download. Secure and encrypted file retrieval landing page.">
    <meta name="author" content="Phoenix">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/icons/safari-pinned-tab.svg" color="#6366f1">
    <meta name="apple-mobile-web-app-title" content="Phoenix XShare">
    <meta name="application-name" content="Phoenix XShare">
    <meta name="msapplication-TileColor" content="#0b0f19">
    <meta name="theme-color" content="#0b0f19">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/download.css">
    <title>Phoenix XShare - Download File</title>
</head>
<body class="auth-body">
<div class="auth-container">
    <div class="glass-card">
        <div class="brand-header text-center">
            <img class="logo-img animate-float" src="/icons/logo-trans.png" alt="Phoenix XShare Logo">
            <h1 class="brand-title">Phoenix XShare</h1>
            <p class="brand-subtitle">Secure File Retrieval</p>
        </div>

        <div class="download-content-box mt-4">
            <div class="file-landing-header d-flex align-items-center mb-3">
                <div class="file-icon-wrapper me-3">
                    <i class="bi bi-file-earmark-arrow-down-fill text-indigo" style="font-size: 2.2rem;"></i>
                </div>
                <div class="file-main-details overflow-hidden">
                    <h3 class="file-display-name text-light text-truncate m-0" title="<%= originalName %>"><%= originalName %></h3>
                    <span class="file-display-size badge bg-success-glow mt-1"><%= fileSize %></span>
                </div>
            </div>

            <div class="file-meta-list py-2">
                <div class="meta-row">
                    <span class="meta-label">Uploaded By</span>
                    <span class="meta-value"><i class="bi bi-person-fill me-1 text-primary"></i> <%= uploader %></span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">Upload Date</span>
                    <span class="meta-value"><i class="bi bi-calendar3 me-1 text-muted"></i> <%= uploadTime %></span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">Privacy Security</span>
                    <span class="meta-value">
                        <% if (encryption === "true") { %>
                            <span class="text-success-bright"><i class="bi bi-lock-fill me-1"></i> AES-256 Encrypted</span>
                        <% } else { %>
                            <span class="text-muted"><i class="bi bi-unlock me-1"></i> Standard Standard</span>
                        <% } %>
                    </span>
                </div>
            </div>

            <!-- DOWNLOAD ACTIONS -->
            <a href="/cdn/<%= fileName %>" id="downloadLink" class="btn-premium btn-glow mt-3 w-100" data-file-name="<%= fileName %>" download="<%= originalName %>">
                <i class="bi bi-cloud-arrow-down-fill me-2"></i> Download File
            </a>

            <!-- QR CODE landing -->
            <div class="qr-landing-section mt-4 text-center">
                <p class="qr-landing-label text-muted mb-2"><i class="bi bi-qr-code"></i> Scan to Download on Mobile</p>
                <div class="qr-canvas-wrapper p-2 bg-white rounded-3 d-inline-block shadow-lg">
                    <img class="qr-image-landing" src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=http://localhost:3000/cdn/<%= fileName %>" id="landingQrCode" alt="QR Code">
                </div>
            </div>
        </div>

        <div id="errorBox" class="error-box mt-3" style="display: none;"></div>

        <div class="auth-footer mt-4">
            Return to <a href="/" class="gradient-link">Dashboard</a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
<script src="/scripts/download.js" type="module"></script>
<script src="/scripts/registerSW.js" type="module"></script>
<script src="https://storage.googleapis.com/workbox-cdn/releases/6.1.5/workbox-sw.js"></script>
<script>
    // Dynamically adjust landing QR code based on window location domain!
    document.addEventListener('DOMContentLoaded', () => {
        const qrImg = document.getElementById('landingQrCode');
        if (qrImg) {
            const fileCdnUrl = `${window.location.protocol}//${window.location.host}/cdn/<%= fileName %>`;
            qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(fileCdnUrl)}`;
        }
    });
</script>
</body>
</html>
