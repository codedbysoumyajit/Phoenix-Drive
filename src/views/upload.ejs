<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Phoenix-XShare upload dashboard. Upload multiple files securely with encryption and manage your cloud inventory.">
    <meta name="author" content="Phoenix">
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/icons/safari-pinned-tab.svg" color="#6366f1">
    <meta name="apple-mobile-web-app-title" content="Phoenix XShare">
    <meta name="application-name" content="Phoenix XShare">
    <meta name="msapplication-TileColor" content="#0b0f19">
    <meta name="theme-color" content="#0b0f19">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/upload.css">
    <title>Phoenix XShare - Workspace</title>
</head>
<body class="dashboard-body">
<div class="dashboard-wrapper">
    <!-- Navbar / Header -->
    <header class="workspace-header">
        <div class="header-brand">
            <img class="logo-mini animate-float" src="/icons/logo-trans.png" alt="Logo">
            <span class="brand-text">Phoenix XShare</span>
        </div>
        <div class="header-user-actions">
            <span class="user-greeting"><i class="bi bi-person-circle text-primary"></i> <%= username %></span>
            <a href="/logout" class="btn-logout"><i class="bi bi-box-arrow-right"></i> Log Out</a>
        </div>
    </header>

    <main class="workspace-main mt-4">
        <!-- TOP: UPLOAD BOX -->
        <section class="glass-section p-4 mb-4">
            <div class="section-title-group mb-3">
                <h2 class="section-title"><i class="bi bi-cloud-arrow-up-fill text-indigo"></i> Upload Files</h2>
                <p class="section-subtitle">Select or drag & drop files to upload securely. Encryption: 
                    <% if (encryptionEnabled) { %>
                        <span class="badge bg-success-glow"><i class="bi bi-lock-fill"></i> Enabled</span>
                    <% } else { %>
                        <span class="badge bg-secondary-glow"><i class="bi bi-unlock-fill"></i> Disabled</span>
                    <% } %>
                </p>
            </div>

            <form id="uploadForm" action="/upload" method="POST" enctype="multipart/form-data">
                <input type="file" name="file" id="fileInput" class="hidden-file-input" accept="*/*" multiple>

                <label for="fileInput" id="fileSelectionArea" class="file-selection-area">
                    <i class="bi bi-clouds upload-icon"></i>
                    <span class="drag-drop-text">Drag & Drop files here or click to browse</span>
                    <span class="sub-text">Supports uploading multiple files at once</span>
                </label>

                <!-- QUEUED FILES PANEL -->
                <div id="queueContainer" class="queue-container hidden mt-3">
                    <h3 class="panel-subtitle"><i class="bi bi-list-task"></i> Upload Queue</h3>
                    <div id="queueList" class="queue-list mt-2"></div>
                </div>

                <div class="action-buttons-row mt-4">
                    <button type="submit" class="btn-premium btn-glow d-none" id="uploadTriggerButton">
                        <i class="bi bi-cloud-upload"></i> Start Secure Upload
                    </button>
                </div>
            </form>

            <!-- PROGRESS OVERLAY -->
            <div id="progressBarContainer" class="progress-bar-container hidden mt-4">
                <div class="progress-info-row mb-2">
                    <span class="progress-message" id="progressMessage">Preparing upload...</span>
                    <span class="progress-percentage" id="progressPercentage">0%</span>
                </div>
                <div class="progress-bar-wrapper mb-2">
                    <div id="progressBar" class="progress-bar-fill"></div>
                </div>
                <div class="upload-status" id="uploadStatus"></div>
            </div>

            <!-- SUCCESS PANEL -->
            <div id="successPanel" class="success-panel hidden mt-4">
                <div class="alert bg-success-opaque border-success-glow text-light mb-3">
                    <h4 class="alert-heading m-0"><i class="bi bi-check-circle-fill text-success-bright me-2"></i> Files uploaded successfully!</h4>
                </div>
                <div id="successFilesList" class="success-files-list"></div>
                <div class="text-end mt-3">
                    <button id="closeSuccessBtn" class="btn-outline-glow"><i class="bi bi-arrow-left"></i> Done</button>
                </div>
            </div>
        </section>

        <!-- BOTTOM: DASHBOARD FILE MANAGER -->
        <section class="glass-section p-4">
            <div class="dashboard-header-row mb-3 flex-column flex-md-row">
                <div class="section-title-group mb-2 mb-md-0">
                    <h2 class="section-title"><i class="bi bi-folder-fill text-cyan"></i> Cloud Inventory</h2>
                    <p class="section-subtitle">Manage and share your uploaded items securely</p>
                </div>
                <div class="search-bar-group">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="searchFilesInput" class="search-input" placeholder="Search by file name...">
                </div>
            </div>

            <!-- FILES CONTAINER -->
            <div class="table-responsive inventory-table-wrapper">
                <table class="inventory-table align-middle">
                    <thead>
                        <tr>
                            <th>File Name</th>
                            <th>Size</th>
                            <th>Upload Date</th>
                            <th class="text-center">Encryption</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="inventoryBody">
                        <% if (files.length === 0) { %>
                            <tr id="emptyStateRow">
                                <td colspan="5" class="text-center py-5">
                                    <div class="empty-state">
                                        <i class="bi bi-folder-symlink empty-icon"></i>
                                        <h3 class="empty-title">Your inventory is empty</h3>
                                        <p class="empty-desc text-muted">Upload your first files using the dropzone above!</p>
                                    </div>
                                </td>
                            </tr>
                        <% } else { %>
                            <% files.forEach(file => { %>
                                <tr data-filename="<%= file.filename %>" data-originalname="<%= file.originalName || file.filename %>">
                                    <td class="file-name-cell">
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-file-earmark-code file-type-icon me-2 text-indigo"></i>
                                            <div class="text-truncate" style="max-width: 250px;">
                                                <span class="file-label-name" title="<%= file.originalName || file.filename %>"><%= file.originalName || file.filename %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="file-size-badge"><%= file.fileSize %></span></td>
                                    <td class="text-muted"><%= file.uploadTime %></td>
                                    <td class="text-center">
                                        <% if (file.encryption === "true") { %>
                                            <span class="enc-indicator text-success-bright" title="Encrypted on disk"><i class="bi bi-lock-fill"></i></span>
                                        <% } else { %>
                                            <span class="enc-indicator text-muted" title="Not encrypted"><i class="bi bi-unlock"></i></span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group-actions">
                                            <a href="/view/<%= file.filename %>" class="btn-action-icon text-cyan" title="Preview File"><i class="bi bi-eye-fill"></i></a>
                                            <button class="btn-action-icon text-indigo btn-copy-share" data-link="<%= domain %>/download/<%= file.filename %>" title="Copy Download Link"><i class="bi bi-share-fill"></i></button>
                                            <button class="btn-action-icon text-indigo btn-copy-cdn" data-link="<%= domain %>/cdn/<%= file.filename %>" title="Copy Direct Link"><i class="bi bi-code-slash"></i></button>
                                            <button class="btn-action-icon text-warning btn-show-qr" data-link="<%= domain %>/cdn/<%= file.filename %>" title="Show QR Code"><i class="bi bi-qr-code"></i></button>
                                            <button class="btn-action-icon text-danger btn-delete-file" data-filename="<%= file.filename %>" title="Delete File"><i class="bi bi-trash3-fill"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="workspace-footer mt-5 mb-4 text-center text-muted">
        <p class="m-0"><i class="bi bi-lightning-charge-fill text-indigo"></i> Powered By Phoenix XShare v3.0</p>
    </footer>
</div>

<!-- MODERN DETAILED MODALS -->
<!-- 1. DELETION MODAL -->
<div class="custom-modal-overlay hidden" id="deleteModal">
    <div class="custom-modal-card glass-card max-w-sm">
        <div class="modal-header-section text-center">
            <div class="warning-icon-wrapper mb-3">
                <i class="bi bi-exclamation-triangle-fill text-danger animate-pulse"></i>
            </div>
            <h3 class="modal-title text-light">Confirm Deletion</h3>
            <p class="modal-desc text-muted mt-2">Are you sure you want to delete the file <strong id="deleteFileNameDisplay" class="text-light"></strong>? This action is permanent and cannot be undone.</p>
        </div>
        <div class="modal-actions-section mt-4 d-flex gap-3">
            <button class="btn-premium bg-danger w-50" id="confirmDeleteBtn"><i class="bi bi-trash3"></i> Delete</button>
            <button class="btn-outline-glow w-50" id="cancelDeleteBtn">Cancel</button>
        </div>
    </div>
</div>

<!-- 2. QR CODE MODAL -->
<div class="custom-modal-overlay hidden" id="qrModal">
    <div class="custom-modal-card glass-card max-w-sm text-center">
        <h3 class="modal-title text-light mb-3">Scan QR Code</h3>
        <div class="qr-canvas-wrapper p-3 bg-white rounded-4 d-inline-block shadow-lg mb-3">
            <img id="modalQrCodeImg" class="qr-image" src="" alt="QR Code">
        </div>
        <p class="modal-desc text-muted mb-4">Scan this code with a mobile device to download the file directly.</p>
        <button class="btn-outline-glow w-100" id="closeQrModalBtn">Close</button>
    </div>
</div>

<!-- TOAST MESSAGE NOTIFICATIONS -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
    <div id="appToast" class="toast align-items-center text-white bg-dark border-0 glass-toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center">
                <i class="bi bi-info-circle-fill me-2 text-primary"></i>
                <span id="toastText">Message copied!</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<script src="/scripts/upload.js" type="module"></script>
<script src="/scripts/registerSW.js" type="module"></script>
<script src="https://storage.googleapis.com/workbox-cdn/releases/6.1.5/workbox-sw.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
</body>
</html>
